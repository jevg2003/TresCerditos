</div>

<script>
  const fabMain = document.getElementById('fab-main');
  const fabMenu = document.getElementById('fab-menu');
  const iconPlate = document.getElementById('icon-plate');
  const iconClose = document.getElementById('icon-close');
  const fabContainer = document.getElementById('contact-fab-container');
  const footer = document.querySelector('footer');

  let isOpen = false;

  fabMain?.addEventListener('click', (e) => {
    e.stopPropagation();
    isOpen = !isOpen;
    
    if (isOpen) {
      // Toggle Menu
      fabMenu?.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
      fabMenu?.classList.add('pointer-events-auto');
      
      // Toggle Icons
      iconPlate?.classList.add('opacity-0', 'rotate-90', 'scale-50');
      iconClose?.classList.remove('opacity-0', 'scale-50');
      iconClose?.classList.add('opacity-100', 'scale-100', 'rotate-0');
      
      fabMain?.classList.add('ring-4', 'ring-red-500/20');
    } else {
      // Toggle Menu
      fabMenu?.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
      fabMenu?.classList.remove('pointer-events-auto');
      
      // Toggle Icons
      iconPlate?.classList.remove('opacity-0', 'rotate-90', 'scale-50');
      iconClose?.classList.add('opacity-0', 'scale-50');
      iconClose?.classList.remove('opacity-100', 'scale-100', 'rotate-0');
      
      fabMain?.classList.remove('ring-4', 'ring-red-500/20');
    }
  });

  // Close when clicking outside
  document.addEventListener('click', () => {
    if (isOpen) {
      isOpen = false;
      fabMenu?.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
      fabMenu?.classList.remove('pointer-events-auto');
      
      iconPlate?.classList.remove('opacity-0', 'rotate-90', 'scale-50');
      iconClose?.classList.add('opacity-0', 'scale-50');
      iconClose?.classList.remove('opacity-100', 'scale-100', 'rotate-0');
      
      fabMain?.classList.remove('ring-4', 'ring-red-500/20');
    }
  });

  // Footer scroll logic
  window.addEventListener('scroll', () => {
    if (footer && fabContainer) {
      const footerTop = footer.getBoundingClientRect().top;
      const windowHeight = window.innerHeight;
      
      if (footerTop < windowHeight + 50) {
        fabContainer.style.opacity = '0';
        fabContainer.style.pointerEvents = 'none';
        fabContainer.style.transform = 'translateY(20px)';
      } else {
        fabContainer.style.opacity = '1';
        fabContainer.style.pointerEvents = 'none'; // Background container always transparent to touches
        fabContainer.style.transform = 'translateY(0)';
      }
    }
  });
</script>