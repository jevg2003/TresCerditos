      <!-- Close SVG (Professional replacement for ✕) -->
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-full h-full absolute inset-0 m-auto opacity-0 scale-50 transition-all duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
