  <button id="fab-main" class="bg-gradient-to-br from-red-500 to-red-700 text-white w-16 h-16 rounded-[1.5rem] shadow-[0_20px_40px_rgba(239,68,68,0.4)] flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-500 relative overflow-hidden group pointer-events-auto z-10 border-2 border-white/20">
    <div id="fab-icon-container" class="relative z-10 w-8 h-8 flex items-center justify-center transform transition-transform duration-500">
      <!-- Utensils SVG (Professional & Symmetric) -->
