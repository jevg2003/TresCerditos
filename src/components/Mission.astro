---
const mision = "Preparar y ofrecer el auténtico sabor de la lechona tradicional vallecaucana, trabajando todos los días con esfuerzo, dedicación y seleccionando los mejores ingredientes para llevar un plato delicioso y de calidad a la mesa de nuestros clientes.";
const vision = "Aprender y mejorar constantemente para brindar una experiencia y un producto cada vez mejor. Aspiramos a ganarnos el corazón de más personas a través de nuestro trabajo diario, sin perder nunca nuestra esencia ni el sabor de hogar.";
---
<section id="nosotros" class="py-12 reveal">
  <div class="grid md:grid-cols-12 gap-8 items-stretch">
    <div class="md:col-span-7 bg-zinc-900 text-white p-10 md:p-12 rounded-[3rem] shadow-2xl relative overflow-hidden group">
      <h2 class="text-4xl md:text-5xl font-black mb-6 italic uppercase">Nuestra <span class="text-red-600">Misión</span></h2>
      <p class="text-lg md:text-xl text-zinc-300 italic font-medium leading-relaxed">"{mision}"</p>
    </div>

    <div class="md:col-span-5 bg-red-600 p-10 md:p-12 rounded-[3rem] shadow-xl md:rotate-2 hover:rotate-0 transition-transform duration-500 flex flex-col justify-center">
      <h2 class="text-3xl md:text-4xl font-black mb-4 uppercase text-white italic">Visión</h2>
      <p class="text-white/90 font-bold text-lg md:text-xl leading-relaxed">{vision}</p>
    </div>
  </div>
</section>