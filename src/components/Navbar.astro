<style>
  /* 1. CLASE PARA BLOQUEAR SCROLL */
  :global(body.overflow-hidden) {
    overflow: hidden;
  }

  /* Animación de la Hamburguesa a X */
  #menu-btn.is-open .line-1 {
    transform: translateY(10px) rotate(45deg);
  }
  #menu-btn.is-open .line-2 {
    opacity: 0;
    transform: translateX(10px);
  }
  #menu-btn.is-open .line-3 {
    transform: translateY(-10px) rotate(-45deg);
  }

  /* Animación del Menú */
  #mobile-menu.show {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }
  /* Clase para ocultar el navbar */
  .nav-hidden {
    transform: translateY(-100%);
  }
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.nav-link-mobile');
  const body = document.body;

  function toggleMenu() {
    const isOpen = btn?.classList.toggle('is-open');
    
    if (isOpen) {
      // 2. BLOQUEAR SCROLL
      body.classList.add('overflow-hidden');
      menu?.classList.remove('hidden');
      setTimeout(() => menu?.classList.add('show'), 10);
    } else {
      // 3. LIBERAR SCROLL
      body.classList.remove('overflow-hidden');
      menu?.classList.remove('show');
      setTimeout(() => menu?.classList.add('hidden'), 300);
    }
  }

  btn?.addEventListener('click', toggleMenu);

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (btn?.classList.contains('is-open')) toggleMenu();
    });
  });

  // 4. LIMPIADOR PARA PANTALLA COMPLETA (RESIZE)
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) { // 768px es el breakpoint 'md' de Tailwind
      if (btn?.classList.contains('is-open')) {
        toggleMenu(); // Esto cierra el menú y libera el scroll automáticamente
      }
    }
  });
  // 5. Lógica de Ocultar/Mostrar Navbar al hacer Scroll
  const nav = document.getElementById('main-nav');
  let lastScrollY = window.scrollY;

  window.addEventListener('scroll', () => {
    if (window.innerWidth < 768) {
      if (window.scrollY > lastScrollY && window.scrollY > 100) {
        // Haciendo scroll hacia abajo en móvil - Ocultar
        nav?.classList.add('nav-hidden');
      } else {
        // Haciendo scroll hacia arriba en móvil - Mostrar
        nav?.classList.remove('nav-hidden');
      }
    } else {
      // En desktop siempre visible
      nav?.classList.remove('nav-hidden');
    }
    lastScrollY = window.scrollY;
  });
</script>