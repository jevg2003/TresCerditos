    </div>

    <button class="md:hidden relative w-10 h-10 flex items-center justify-center group" id="menu-btn" aria-label="Abrir menú">
      <div class="flex flex-col gap-1.5 w-6 transition-all duration-300" id="hamburger-icon">
        <span class="w-full h-1 bg-red-600 rounded-full transition-all duration-300 origin-center line-1"></span>
        <span class="w-full h-1 bg-red-600 rounded-full transition-all duration-300 line-2"></span>
        <span class="w-full h-1 bg-red-600 rounded-full transition-all duration-300 origin-center line-3"></span>
      </div>
