  <div id="mobile-menu" class="hidden md:hidden absolute top-24 left-0 w-full bg-white/95 dark:bg-zinc-950/95 backdrop-blur-2xl border-b border-zinc-200 dark:border-zinc-800 p-8 space-y-6 shadow-2xl origin-top transition-all duration-300 opacity-0 -translate-y-4">
    <div class="flex flex-col gap-6 text-center">
      <a href="#inicio" class="nav-link-mobile text-xl font-black text-zinc-900 dark:text-white uppercase italic tracking-tighter hover:text-red-600 transition-colors">Inicio</a>
      <a href="#productos" class="nav-link-mobile text-xl font-black text-zinc-900 dark:text-white uppercase italic tracking-tighter hover:text-red-600 transition-colors">Menú</a>
      <a href="#galeria" class="nav-link-mobile text-xl font-black text-zinc-900 dark:text-white uppercase italic tracking-tighter hover:text-red-600 transition-colors">Galería</a>
