      <div class="hidden md:flex items-baseline gap-2">
        <span class="font-black text-2xl md:text-3xl tracking-tighter text-zinc-900 dark:text-white uppercase leading-none">
          Lechoneria
        </span>
        <span class="font-bold text-lg md:text-xl tracking-tight text-red-600 uppercase leading-none">
          Tres Cerditos
        </span>
      </div>
    </a>
    
    <div class="hidden lg:flex items-center gap-10 text-xs font-black uppercase tracking-widest text-zinc-600 dark:text-zinc-200">
      <a href="#inicio" class="hover:text-red-600 transition-colors">Inicio</a>
      <a href="#productos" class="hover:text-red-600 transition-colors">Menú</a>
      <a href="#nosotros" class="hover:text-red-600 transition-colors">Nosotros</a>
