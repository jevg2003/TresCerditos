---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/imagen-01.png';
---
<section id="inicio" class="relative h-screen w-full overflow-hidden">
  <img 
    src={heroImage.src} 
    alt="Lechoneria Tres Cerditos Cali" 
    class="absolute inset-0 w-full h-full object-cover scale-105"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
  />
  
  <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-black/80 md:bg-gradient-to-r md:from-black/90 md:via-black/40 md:to-transparent flex items-center pt-20 md:pt-32">
    
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-2xl space-y-4 md:space-y-6">
        
        <span class="inline-block bg-red-500 shadow-[0_0_15px_rgba(239,68,68,0.5)] text-white px-4 py-1.5 rounded-full text-[10px] md:text-sm font-bold uppercase tracking-widest">
          Tradición en cada bocado
        </span>

        <h1 class="text-4xl sm:text-6xl md:text-8xl font-black text-white leading-[0.95] md:leading-[0.9] uppercase italic">
          Las Mejores <br class="hidden sm:block"/> 
          Lechonas en <span class="text-red-600">Cali</span>
        </h1>

        <p class="text-gray-300 text-base md:text-xl font-light max-w-lg leading-relaxed">
          Llevamos el sabor auténtico del Tolima a tu mesa con la receta secreta de la familia.
        </p>

        <div class="flex flex-wrap gap-4 pt-2 md:pt-4">
          <a href="#productos" class="w-full sm:w-auto bg-red-600 text-white md:bg-white md:text-black hover:bg-red-700 md:hover:bg-red-600 md:hover:text-white px-10 py-4 rounded-full font-black text-center transition-all uppercase tracking-tighter md:tracking-normal">
            Ver el menú
          </a>
        </div>

      </div>
    </div>
  </div>
</section>