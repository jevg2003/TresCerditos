---
import { Image } from 'astro:assets';

// Static assets for maximum build stability
import img1 from '../assets/images/imagen-01.png';
import img2 from '../assets/images/imagen-02.png';
import img3 from '../assets/images/imagen-03.png';
import img4 from '../assets/images/imagen-04.png';
import img5 from '../assets/images/imagen-05.png';
import img26 from '../assets/images/imagen-26.jpg';

const allMedia = [
  { src: img1, type: 'img' as const, alt: 'Lechoneria Tres Cerditos Cali - Hero' },
  { src: img2, type: 'img' as const, alt: 'Lechoneria Tres Cerditos Cali - Pernil' },
  { src: img3, type: 'img' as const, alt: 'Lechoneria Tres Cerditos Cali - Cojin' },
  { src: img5, type: 'img' as const, alt: 'Lechoneria Tres Cerditos Cali - Tradicional' },
  { src: '/images/video-36.mp4', type: 'video' as const, alt: 'Preparación de Lechona' },
  { src: img26, type: 'img' as const, alt: 'Nuestros Productos' },
  { src: '/images/video-37.mp4', type: 'video' as const, alt: 'Sabor Tradicional' },
];
---

<section id="galeria" class="py-10 md:py-16 bg-white dark:bg-zinc-950 reveal overflow-hidden">
  <div class="w-full">
    
    <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6 px-6 md:px-12">
      <div class="text-center md:text-left">
        <h2 class="text-4xl md:text-6xl font-black uppercase italic text-zinc-900 dark:text-white">
          Nuestra <span class="text-red-700">Galería</span>
        </h2>
        <p class="text-zinc-500 dark:text-zinc-400 font-medium mt-2">Momentos capturados para tu paladar.</p>
      </div>
      
      <div class="flex items-center justify-center md:justify-end gap-3" id="gallery-controls">
        
        <button id="master-pause" class="control-box active:scale-95 cursor-pointer hover:bg-zinc-200 transition-colors" aria-label="Alternar pausa o reproducción de la galería automática">
          <div class="relative w-6 h-6 flex items-center justify-center text-red-700">
            <svg id="pause-icon" class="w-6 h-6 text-red-700 font-bold" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <svg id="play-icon" class="w-6 h-6 text-red-700 font-bold hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span class="text-xs font-black uppercase tracking-[0.2em] text-zinc-600 dark:text-zinc-400" id="pause-text">Pausar</span>
        </button>

        <div class="control-box font-bold">
          <span id="current-index-display" class="text-2xl font-black text-red-700 italic leading-none">01</span>
          <div class="w-px h-6 bg-zinc-300 dark:bg-zinc-700"></div>
          <span class="text-sm font-bold text-zinc-400 uppercase tracking-widest leading-none">{allMedia.length.toString().padStart(2, '0')}</span>
        </div>
      </div>
    </div>
    
    <div id="gallery-observer-target" class="relative group w-full h-[45vh] md:h-[55vh] max-h-[600px] overflow-hidden bg-black border-y border-zinc-200 dark:border-zinc-800 touch-pan-y">
      <!-- IMAGE ELEMENT -->
      {allMedia.length > 0 && allMedia[0].type === 'img' && (
        <img 
          id="main-stage" 
          src={(allMedia[0].src as any).src || allMedia[0].src} 
          alt="Visualización de galería" 
          class="relative w-full h-full object-contain transition-all duration-700 ease-in-out z-10 hover:scale-105 select-none pointer-events-none"
          loading="eager"
          decoding="sync"
          fetchpriority="high"
        />
      )}
      
      <!-- VIDEO ELEMENT -->
      {allMedia.length > 0 && (
        <video
          id="main-video"
          src={allMedia[0].type === 'video' ? allMedia[0].src : ''}
          class={`relative w-full h-full object-contain z-10 ${allMedia[0].type === 'video' ? '' : 'hidden'}`}
          muted loop playsinline
        ></video>
      )}

      <div class="absolute inset-0 z-30 opacity-0 group-hover:opacity-100 transition-opacity duration-500 hidden md:flex items-center justify-between px-8 pointer-events-none">
        <button id="prev-btn" class="pointer-events-auto w-14 h-14 rounded-2xl bg-white/10 dark:bg-black/40 backdrop-blur-xl border border-white/20 text-white flex items-center justify-center -translate-x-10 group-hover:translate-x-0 opacity-0 group-hover:opacity-100 transition-all duration-500 hover:bg-red-700" aria-label="Ver imagen anterior de la galería">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="next-btn" class="pointer-events-auto w-14 h-14 rounded-2xl bg-white/10 dark:bg-black/40 backdrop-blur-xl border border-white/20 text-white flex items-center justify-center translate-x-10 group-hover:translate-x-0 opacity-0 group-hover:opacity-100 transition-all duration-500 hover:bg-red-700" aria-label="Ver siguiente imagen de la galería">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
        </button>
      </div>

      <div class="absolute bottom-0 left-0 h-1.5 bg-red-700 z-40 transition-all duration-[4000ms] ease-linear w-0" id="progress-bar"></div>
    </div>

    <div class="mt-12 relative px-6 md:px-12 group/thumbs flex items-center">
      <button id="thumb-prev-scroll" aria-label="Anterior imagen" class="pointer-events-none group-hover/thumbs:pointer-events-auto hidden md:flex absolute left-0 z-10 w-12 h-12 items-center justify-center bg-white dark:bg-zinc-900 rounded-full shadow-lg border border-zinc-200 dark:border-zinc-800 hover:scale-110 transition-all opacity-0 group-hover/thumbs:opacity-100 text-zinc-800 dark:text-zinc-200 hover:text-red-600 dark:hover:text-red-500 disabled:opacity-0">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
      </button>

      <div id="thumb-container" class="flex gap-3 md:gap-4 overflow-x-auto pb-6 scroll-smooth snap-x snap-mandatory no-scrollbar cursor-grab active:cursor-grabbing w-full px-2 md:px-12">
        {allMedia.map((media, index) => (
          <button 
            class="thumb-btn flex-shrink-0 w-20 h-20 md:w-32 md:h-24 rounded-xl md:rounded-2xl overflow-hidden snap-start relative transition-all duration-300 opacity-40 hover:opacity-100 border-2 border-transparent"
            data-src={media.type === 'img' ? (media.src as any).src : media.src}
            data-type={media.type}
            data-index={index}
          >
            {media.type === 'video' ? (
              <div class="w-full h-full relative">
                <video src={media.src as string} class="w-full h-full object-cover pointer-events-none" preload="metadata" muted />
                <div class="absolute inset-0 flex items-center justify-center bg-black/40">
                  <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4l12 6-12 6z"/></svg>
                </div>
              </div>
            ) : (
              <img src={(media.src as any).src} alt={media.alt} width="128" height="96" class="w-full h-full object-cover pointer-events-none" loading="lazy" />
            )}
          </button>
        ))}
      </div>

      <button id="thumb-next-scroll" aria-label="Siguiente imagen" class="pointer-events-none group-hover/thumbs:pointer-events-auto hidden md:flex absolute right-0 z-10 w-12 h-12 items-center justify-center bg-white dark:bg-zinc-900 rounded-full shadow-lg border border-zinc-200 dark:border-zinc-800 hover:scale-110 transition-all opacity-0 group-hover/thumbs:opacity-100 text-zinc-800 dark:text-zinc-200 hover:text-red-600 dark:hover:text-red-500 disabled:opacity-0">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .control-box {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.75rem; 
    min-height: 3.5rem; 
    background-color: var(--color-zinc-100);
    border-radius: 1.25rem;
    border: 1px solid var(--color-zinc-200);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.dark) .control-box {
    background-color: var(--color-zinc-900);
    border-color: var(--color-zinc-800);
  }

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  
  .thumb-btn.is-active {
    opacity: 1 !important;
    border-color: var(--color-red-700);
    transform: translateY(-8px) scale(1.05);
    box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.3);
  }
</style>

<script>
  const thumbBtns = document.querySelectorAll('.thumb-btn');
  const mainImg = document.getElementById('main-stage') as HTMLImageElement;
  const mainVideo = document.getElementById('main-video') as HTMLVideoElement;
  const bgBlur = document.getElementById('bg-blur') as HTMLImageElement;
  const progressBar = document.getElementById('progress-bar');
  const container = document.getElementById('thumb-container');
  const indexDisplay = document.getElementById('current-index-display');
  const galleryBox = document.getElementById('gallery-observer-target');
  
  const pauseBtn = document.getElementById('master-pause');
  const pauseText = document.getElementById('pause-text');
  const pauseIcon = document.getElementById('pause-icon');
  const playIcon = document.getElementById('play-icon');
  
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  let currentIndex = 0;
  let interval: any;
  let isPaused = false;
  let isVisible = false;
  let touchStartX = 0;
  let isUserInteracting = false;
  let interactionTimeout: any;

  function setInteracting() {
    isUserInteracting = true;
    clearTimeout(interactionTimeout);
    interactionTimeout = setTimeout(() => {
      isUserInteracting = false;
    }, 3000); // 3 segundos sin tocar para retomar el scroll automático
  }

  container?.addEventListener('mousedown', setInteracting);
  container?.addEventListener('touchstart', setInteracting, { passive: true });
  container?.addEventListener('wheel', setInteracting, { passive: true });

  function updateGallery(index: number) {
    currentIndex = index;
    const btn = thumbBtns[index];
    if(!btn) return;
    const newSrc = btn.getAttribute('data-src');
    const type = btn.getAttribute('data-type');

    if (mainVideo) mainVideo.pause();

    if (!isPaused) startAutoPlay();

    if (indexDisplay) {
      indexDisplay.textContent = (index + 1).toString().padStart(2, '0');
    }

    if (type === 'video') {
      if (mainImg) mainImg.classList.add('hidden');
      if (mainVideo && newSrc) {
        mainVideo.classList.remove('hidden');
        mainVideo.src = newSrc;
        if (!isPaused && isVisible) {
          mainVideo.play().catch(e => console.log('Auto-play prevent:', e));
        }
      }
      if (bgBlur) bgBlur.style.opacity = '0';
    } else {
      if (mainVideo) mainVideo.classList.add('hidden');
      if (mainImg && newSrc) {
        mainImg.classList.remove('hidden');
        mainImg.style.opacity = '0.5';
        setTimeout(() => {
          mainImg.src = newSrc;
          if (bgBlur) {
            bgBlur.src = newSrc;
            bgBlur.style.opacity = '0.4';
          }
          mainImg.style.opacity = '1';
        }, 150);
      }
    }

    thumbBtns.forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');

    if (progressBar) {
        progressBar.style.transition = 'none';
        progressBar.style.width = '0%';
        if (!isPaused && isVisible) {
          setTimeout(() => {
              progressBar.style.transition = 'width 4000ms linear';
              progressBar.style.width = '100%';
          }, 50);
        }
    }
  }

  function startAutoPlay() {
    clearInterval(interval);
    if (isPaused) return;
    interval = setInterval(() => {
      if (isVisible && !isPaused) {
        currentIndex = (currentIndex + 1) % thumbBtns.length;
        updateGallery(currentIndex);
      }
    }, 4000);
  }

  function stopAutoPlay() {
    if (interval) clearInterval(interval);
  }

  pauseBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    isPaused = !isPaused;
    
    pauseIcon?.classList.toggle('hidden', isPaused);
    playIcon?.classList.toggle('hidden', !isPaused);
    
    if (pauseText) {
      pauseText.textContent = isPaused ? "Reanudar" : "Pausar";
    }

    if (isPaused) {
      stopAutoPlay();
      if (progressBar) progressBar.style.width = '0%';
      if (mainVideo) mainVideo.pause();
    } else {
      startAutoPlay();
      updateGallery(currentIndex);
    }
  });

  galleryBox?.addEventListener('touchstart', (e: any) => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
  galleryBox?.addEventListener('touchend', (e: any) => {
    const diff = touchStartX - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) currentIndex = (currentIndex + 1) % allMedia.length;
      else currentIndex = (currentIndex - 1 + allMedia.length) % allMedia.length;
      updateGallery(currentIndex);
    }
  }, { passive: true });

  prevBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + allMedia.length) % allMedia.length;
    updateGallery(currentIndex);
  });
  nextBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % allMedia.length;
    updateGallery(currentIndex);
  });
  thumbBtns.forEach((btn, i) => btn.addEventListener('click', () => updateGallery(i)));

  // Control over visibility for video playback and autoplay
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      isVisible = entry.isIntersecting;
      if (isVisible) {
        if (!isPaused) {
          startAutoPlay();
          if (mainVideo && !mainVideo.classList.contains('hidden')) {
             mainVideo.play().catch(e=>console.log(e));
          }
        }
      } else {
        stopAutoPlay();
        if (mainVideo) mainVideo.pause();
      }
    });
  }, { threshold: 0.1 }); // Trigger pause early when scrolling away

  if (galleryBox) observer.observe(galleryBox);

  // Manual scroll buttons for thumbnails
  const thumbPrevScroll = document.getElementById('thumb-prev-scroll');
  const thumbNextScroll = document.getElementById('thumb-next-scroll');
  
  thumbPrevScroll?.addEventListener('click', () => {
    container?.scrollBy({ left: -300, behavior: 'smooth' });
  });
  
  thumbNextScroll?.addEventListener('click', () => {
    container?.scrollBy({ left: 300, behavior: 'smooth' });
  });
  
  // Initialize
  setTimeout(() => updateGallery(0), 100);
</script>