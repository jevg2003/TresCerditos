---
const images = [
  { src: "https://images.unsplash.com/photo-1544025162-d76694265947?q=80&w=1000", alt: "Lechona Tradicional" },
  { src: "https://images.unsplash.com/photo-1606787366850-de6330128bfc?q=80&w=1000", alt: "Nuestros Ingredientes" },
  { src: "https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=1000", alt: "Plato Especial" },
  { src: "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?q=80&w=1000", alt: "Evento Familiar" },
];
---

<section id="galeria" class="py-20 bg-white dark:bg-zinc-950 rounded-2xl shadow-2xl reveal">
  <div class="max-w-7xl mx-auto px-4">
    
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="text-center md:text-left">
        <h2 class="text-4xl md:text-6xl font-black uppercase italic text-zinc-900 dark:text-white">
          Nuestra <span class="text-red-700">Galería</span>
        </h2>
        <p class="text-zinc-500 dark:text-zinc-400 font-medium mt-2">Momentos capturados para tu paladar.</p>
      </div>
      
      <div class="flex items-center justify-center md:justify-end gap-3" id="gallery-controls">
        
        <button id="master-pause" class="control-box active:scale-95 cursor-pointer">
          <div class="relative w-6 h-6 flex items-center justify-center text-red-700">
            <svg id="pause-icon" class="w-6 h-6 text-red-700 font-bold" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <svg id="play-icon" class="w-6 h-6 text-red-700 font-bold hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span class="text-xs font-black uppercase tracking-[0.2em] text-zinc-600 dark:text-zinc-400 group-hover:text-white" id="pause-text">Pausar</span>
        </button>

        <div class="control-box font-bold">
          <span id="current-index-display" class="text-2xl font-black text-red-700 italic leading-none">01</span>
          <div class="w-px h-6 bg-zinc-300 dark:bg-zinc-700"></div>
          <span class="text-sm font-bold text-zinc-400 uppercase tracking-widest leading-none">{images.length.toString().padStart(2, '0')}</span>
        </div>
      </div>
    </div>
    
    <div id="gallery-observer-target" class="relative group aspect-video md:aspect-[21/9] rounded-[3rem] overflow-hidden bg-black shadow-2xl border border-zinc-200 dark:border-zinc-800 touch-pan-y">
      <img id="bg-blur" src={images[0].src} class="absolute inset-0 w-full h-full object-cover blur-3xl opacity-40 scale-125 transition-all duration-1000" />
      
      <img 
        id="main-stage" 
        src={images[0].src} 
        alt="Visualización de galería" 
        class="relative w-full h-full object-cover transition-all duration-700 ease-in-out z-10 hover:scale-105 select-none pointer-events-none"
      />

      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

      <div class="absolute inset-0 z-30 opacity-0 group-hover:opacity-100 transition-opacity duration-500 hidden md:flex items-center justify-between px-8">
        <button id="prev-btn" class="pointer-events-auto w-14 h-14 rounded-2xl bg-white/10 dark:bg-black/20 backdrop-blur-xl border border-white/20 text-white flex items-center justify-center -translate-x-20 group-hover:translate-x-0 opacity-0 group-hover:opacity-100 transition-all duration-500 hover:bg-red-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="next-btn" class="pointer-events-auto w-14 h-14 rounded-2xl bg-white/10 dark:bg-black/20 backdrop-blur-xl border border-white/20 text-white flex items-center justify-center translate-x-20 group-hover:translate-x-0 opacity-0 group-hover:opacity-100 transition-all duration-500 hover:bg-red-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
        </button>
      </div>

      <div class="absolute bottom-0 left-0 h-1.5 bg-red-700 z-40 transition-all duration-[4000ms] ease-linear w-0" id="progress-bar"></div>
    </div>

    <div class="mt-12 relative px-2">
      <div id="thumb-container" class="flex gap-4 overflow-x-auto pb-6 scroll-smooth snap-x snap-mandatory no-scrollbar cursor-grab active:cursor-grabbing">
        {images.map((img, index) => (
          <button 
            class="thumb-btn flex-shrink-0 w-24 h-24 md:w-36 md:h-24 rounded-2xl overflow-hidden snap-start relative transition-all duration-300 opacity-40 hover:opacity-100 border-2 border-transparent"
            data-src={img.src}
            data-index={index}
          >
            <img src={img.src} alt={img.alt} class="w-full h-full object-cover pointer-events-none" />
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ESTILO UNIFICADO PARA LOS CAJONES DE CONTROL */
  .control-box {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.75rem; /* Ajustado para que se vea robusto */
    min-height: 3.5rem; /* Forzamos que ambos tengan la misma altura mínima */
    background-color: var(--color-zinc-100);
    border-radius: 1.25rem;
    border: 1px solid var(--color-zinc-200);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Soporte para Modo Oscuro */
  :global(.dark) .control-box {
    background-color: var(--color-zinc-900);
    border-color: var(--color-zinc-800);
  }

  /* Hover específico para el botón de pausa */
  #master-pause:hover {
    border-color: var(--color-red-700);
    background-color: var(--color-white);
  }

  :global(.dark) #master-pause:hover {
    background-color: var(--color-zinc-800);
  }

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  
  .thumb-btn.is-active {
    opacity: 1 !important;
    border-color: var(--color-red-700);
    transform: translateY(-8px) scale(1.05);
    box-shadow: 0 20px 25px -5px rgba(239, 68, 68, 0.2);
  }
</style>

<script>
  // Selección de elementos del DOM
  const thumbBtns = document.querySelectorAll('.thumb-btn');
  const mainImg = document.getElementById('main-stage') as HTMLImageElement;
  const bgBlur = document.getElementById('bg-blur') as HTMLImageElement;
  const progressBar = document.getElementById('progress-bar');
  const container = document.getElementById('thumb-container');
  const indexDisplay = document.getElementById('current-index-display');
  const galleryBox = document.getElementById('gallery-observer-target');
  
  const pauseBtn = document.getElementById('master-pause');
  const pauseText = document.getElementById('pause-text');
  const pauseIcon = document.getElementById('pause-icon');
  const playIcon = document.getElementById('play-icon');
  
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  let currentIndex = 0;
  let interval: any;
  let isPaused = false;
  let isVisible = false;
  let touchStartX = 0;

  function updateGallery(index: number) {
    currentIndex = index;
    const btn = thumbBtns[index];
    if(!btn) return;
    const newSrc = btn.getAttribute('data-src');

    if (!isPaused) startAutoPlay();

    if (indexDisplay) {
      indexDisplay.textContent = (index + 1).toString().padStart(2, '0');
    }

    if (mainImg && newSrc) {
      mainImg.style.opacity = '0.5';
      setTimeout(() => {
        mainImg.src = newSrc;
        if (bgBlur) bgBlur.src = newSrc;
        mainImg.style.opacity = '1';
      }, 150);
    }

    thumbBtns.forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');

    if (container) {
      const btnElem = btn as HTMLElement;
      const scrollPos = btnElem.offsetLeft - (container.offsetWidth / 2) + (btnElem.offsetWidth / 2);
      container.scrollTo({ left: scrollPos, behavior: 'smooth' });
    }

    if (progressBar) {
        progressBar.style.transition = 'none';
        progressBar.style.width = '0%';
        if (!isPaused && isVisible) {
          setTimeout(() => {
              progressBar.style.transition = 'width 4000ms linear';
              progressBar.style.width = '100%';
          }, 50);
        }
    }
  }

  function startAutoPlay() {
    clearInterval(interval);
    if (isPaused) return;
    interval = setInterval(() => {
      if (isVisible && !isPaused) {
        currentIndex = (currentIndex + 1) % thumbBtns.length;
        updateGallery(currentIndex);
      }
    }, 4000);
  }

  function stopAutoPlay() {
    if (interval) clearInterval(interval);
  }

  pauseBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    isPaused = !isPaused;
    
    pauseIcon?.classList.toggle('hidden', isPaused);
    playIcon?.classList.toggle('hidden', !isPaused);
    
    if (pauseText) {
      pauseText.textContent = isPaused ? "Reanudar" : "Pausar";
    }

    if (isPaused) {
      stopAutoPlay();
      if (progressBar) progressBar.style.width = '0%';
    } else {
      startAutoPlay();
      updateGallery(currentIndex);
    }
  });

  // Swipe y navegación
  galleryBox?.addEventListener('touchstart', (e: any) => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
  galleryBox?.addEventListener('touchend', (e: any) => {
    const diff = touchStartX - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) currentIndex = (currentIndex + 1) % thumbBtns.length;
      else currentIndex = (currentIndex - 1 + thumbBtns.length) % thumbBtns.length;
      updateGallery(currentIndex);
    }
  }, { passive: true });

  prevBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + thumbBtns.length) % thumbBtns.length;
    updateGallery(currentIndex);
  });
  nextBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % thumbBtns.length;
    updateGallery(currentIndex);
  });
  thumbBtns.forEach((btn, i) => btn.addEventListener('click', () => updateGallery(i)));

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      isVisible = entry.isIntersecting;
      if (isVisible) startAutoPlay();
      else stopAutoPlay();
    });
  }, { threshold: 0.5 });

  if (galleryBox) observer.observe(galleryBox);
  updateGallery(0);
</script>