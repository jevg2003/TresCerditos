---
const productos = [
  { nombre: "Lechona Tradicional", desc: "Nuestra receta auténtica tolimense con arroz seleccionado, jugosa carne de cerdo desmechada y el característico cuero crocante horneado a la perfección.", imagen: "/images/imagen-05.png" },
  { nombre: "Cojín de Lechona", desc: "El formato ideal para compartir o celebrar eventos especiales. Lechona empacada, lista para dividir en porciones de manera muy práctica.", imagen: "/images/imagen-03.png" },
  { nombre: "Pernil de Cerdo", desc: "Exquisito pernil de cerdo horneado lentamente en sus propios jugos y finas hierbas, garantizando una carne muy suave, tierna y con mucho sabor a hogar.", imagen: "/images/imagen-02.png" },
  { nombre: "Papa Rellena", desc: "Una fusión increíble y deliciosa: crujiente masa de papa por fuera, rellena generosamente con nuestra inconfundible lechona de la casa por dentro.", imagen: "/images/imagen-40.jpeg" },
  { nombre: "Empanada", desc: "Pequeñas delicias con la masa de maíz más crujiente dorada en su punto, conservando todo el sabor auténtico de la lechona en cada bocado rápido.", imagen: "/images/imagen-24.jpg" },
  { nombre: "Tamal con Lechona", desc: "La combinación perfecta y preferida por muchísimos clientes. Delicioso tamal tolimense acompañado con una generosa porción de nuestra mejor lechona.", imagen: "/images/imagen-26.jpg" },
];
---
<section id="productos" class="py-20 reveal">
  <h2 class="text-4xl md:text-6xl font-black mb-12 uppercase italic">Nuestros <span class="text-red-600">Manjares</span></h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {productos.map(p => (
      <div class="bg-zinc-50 p-3 rounded-[2.5rem] border border-zinc-200 hover:shadow-2xl transition-all group flex flex-col h-full">
        <div class="h-64 bg-zinc-200 rounded-[2rem] overflow-hidden relative shrink-0">
            <img src={p.imagen} alt={`${p.nombre} - Lechoneria Tres Cerditos Cali`} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" /> 
        </div>
        <div class="p-6 flex flex-col flex-grow">
          <h3 class="text-2xl font-bold">{p.nombre}</h3>
          <p class="text-zinc-500 text-sm mt-3 leading-relaxed flex-grow">{p.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>